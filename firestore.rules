rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper for transactions
    function isValidTransaction(data) {
      return data.userId == request.auth.uid &&
             data.type in ['income', 'expense', 'sale'] &&
             data.amount is number &&
             data.description is string && data.description.size() <= 200 &&
             data.category is string && data.category.size() <= 50;
    }

    match /transactions/{transactionId} {
      allow create: if isSignedIn() && isValidId(transactionId) && isValidTransaction(request.resource.data);
      allow update: if isSignedIn() && isOwner(resource.data.userId) && 
                      isValidTransaction(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId;
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isOwner(resource.data.userId);
    }

    match /userProfiles/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && 
                     request.resource.data.userId == userId &&
                     request.resource.data.salaryReserve is number;
    }
  }
}
